{
  "manifest_version": 3,
  "name": "boca-plusplus",
  "version": "1.0",
  "description": "Enhances the BOCA programming-contest admin/judge interface: richer runs table (aliases, reordering, inline code viewer with diffs) and score views.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "clipboardWrite"
  ],
  "optional_host_permissions": [
    "*://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Enable Boca++ on this server",
    "default_icon": {
      "16": "icons/icon_gray_16.png",
      "48": "icons/icon_gray_48.png",
      "128": "icons/icon_gray_128.png"
    }
  }
}
